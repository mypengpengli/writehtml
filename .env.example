# ===================================================================
# .env.example  ——  仅本地开发参考，生产部署【不需要】这个文件
# -------------------------------------------------------------------
# 服务器部署用 docker-compose.yml，里面已配好环境变量，无需 .env。
# 每位用户登录后在右上角 ⚙ 设置里填自己的 base_url / api_key / 模型ID / 语音转写模型，
# 因此服务器无需任何共享密钥，也无需邀请码/注册码。
#
# 仅当你在本机直接 `python main.py` 调试时，才把本文件复制为 .env 使用。
# ===================================================================

# ---- 数据库 ----
# SQLite 文件路径。容器内固定为 /data/writehtml.db（由 compose 挂载 ./data:/data）
DB_PATH=./data/writehtml.db

# ---- 服务端口 ----
PORT=9123

# ---- 注册策略 ----
# true  = 开放注册（compose 默认值，任何人可注册账号）
# 留空 SIGNUP_CODE = 注册时不要求注册码
ALLOW_SIGNUP=true
SIGNUP_CODE=

# 想锁死只允许自己注册：把上面改成
#   ALLOW_SIGNUP=true
#   SIGNUP_CODE=你自定义的一串密码
# 然后注册页会要求填这个码。

# ---- LLM 配置（可选 / 服务器级兜底）----
# 正常情况下【留空】即可：用户在 ⚙ 设置里各自填自己的。
# 只有当某用户没在设置里填、又想用服务器默认配置时，这里填的才会生效。
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
ASR_MODEL=whisper-1
