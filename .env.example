# ===== 必改 =====

# OpenAI 兼容的大模型（你自己选厂商和模型）
# 例：DeepSeek   LLM_BASE_URL=https://api.deepseek.com/v1   LLM_MODEL=deepseek-chat
# 例：智谱       LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4   LLM_MODEL=glm-4-flash
# 例：通义       LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   LLM_MODEL=qwen-plus
# 例：OpenAI     LLM_BASE_URL=https://api.openai.com/v1      LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-在这里填你的key
LLM_MODEL=deepseek-chat

# ===== 注册控制（公网部署重要）=====
# 首次部署：先设一个注册码，用它在网页上注册你的账号；建好账号后可清空此码彻底关闭注册。
# 留空 + ALLOW_SIGNUP=false → 完全禁止注册，只能登录已有账号。
SIGNUP_CODE=把它改成你自己的邀请码
ALLOW_SIGNUP=false

# ===== 可选 =====

# SQLite 路径（本地默认 writehtml.db；
# Docker 部署时 compose 会自动设成 /data/writehtml.db，一般不用动）
DB_PATH=writehtml.db

# 服务端口（基本不用的端口；改了的话 docker-compose.yml 里的端口也要一起改）
PORT=9123
